{
  "basic_settings": {
    "description": "基础设置",
    "type": "object",
    "hint": "控制插件启用范围与基础触发条件。",
    "items": {
      "enable_group_split": {
        "description": "群聊分段",
        "hint": "群聊中是否启用分段发送。",
        "type": "bool",
        "default": true
      },
      "split_scope": {
        "description": "分段范围",
        "hint": "只处理 LLM 回复，或连插件输出一起分段。",
        "type": "string",
        "options": ["llm_only", "all"],
        "default": "llm_only"
      },
      "max_length_no_split": {
        "description": "最短触发字数",
        "hint": "文本少于该字数时不分段；填 0 关闭。",
        "type": "int",
        "default": 0
      },
      "max_length_to_disable": {
        "description": "最长处理字数",
        "hint": "文本超过该字数时直接跳过分段；填 0 关闭。",
        "type": "int",
        "default": 0
      },
      "conversation_blacklist": {
        "description": "对话黑名单",
        "hint": "这些对话不会启用分段。",
        "type": "list",
        "default": []
      },
      "conversation_whitelist": {
        "description": "对话白名单",
        "hint": "仅对白名单中的对话启用分段；黑名单优先。",
        "type": "list",
        "default": []
      }
    }
  },
  "split_settings": {
    "description": "分段规则",
    "type": "object",
    "hint": "控制如何识别分段点与均分行为。",
    "items": {
      "split_mode": {
        "description": "分段模式",
        "hint": "Regex 用正则匹配；Simple 用指定文本列表匹配。",
        "type": "string",
        "options": ["regex", "simple"],
        "default": "regex"
      },
      "split_chars": {
        "description": "简单分隔符",
        "hint": "Simple 模式使用。支持完整字符串，如 `< -- >`；换行写 `\\n`。",
        "type": "list",
        "default": ["。", "？", "！", "?", "!", "；", ";", "\n"]
      },
      "split_regex": {
        "description": "正则分隔式",
        "hint": "Regex 模式使用，支持高级正则。",
        "type": "string",
        "default": "[。？！?!\\n…]+"
      },
      "enable_smart_split": {
        "description": "智能识别",
        "hint": "尽量避免在引号、成对符号内部切分。",
        "type": "bool",
        "default": true
      },
      "balanced_split_mode": {
        "description": "智能均分",
        "hint": "按总字数和段数尽量均匀分配每段长度。",
        "type": "bool",
        "default": false
      },
      "max_segments": {
        "description": "最大段数",
        "type": "int",
        "default": 7
      },
      "min_segment_length": {
        "description": "最小段长",
        "hint": "均分模式下避免切出过短碎片。",
        "type": "int",
        "default": 10
      },
      "balanced_split_ratio_min": {
        "description": "均分下限比",
        "hint": "低于理想长度该比例时不切分。",
        "type": "float",
        "default": 0.4
      },
      "balanced_split_ratio_max": {
        "description": "均分上限比",
        "hint": "高于理想长度该比例时尝试次级标点切分。",
        "type": "float",
        "default": 0.9
      },
      "trim_segment_edge_blank_lines": {
        "description": "清理首尾空行",
        "hint": "仅清理每段两端空行，不影响段内换行。",
        "type": "bool",
        "default": true
      }
    }
  },
  "clean_settings": {
    "description": "文本清理",
    "type": "object",
    "hint": "控制分段前后的文本删除与脱敏。",
    "items": {
      "clean_before_items": {
        "description": "前置清理文本",
        "hint": "Simple 模式下，在分段前直接删除这些文本。",
        "type": "list",
        "default": []
      },
      "clean_after_items": {
        "description": "后置清理文本",
        "hint": "Simple 模式下，在分段后逐段删除这些文本。",
        "type": "list",
        "default": []
      },
      "clean_before_regex": {
        "description": "前置清理正则",
        "hint": "Regex 模式下，在分段前执行正则清理。",
        "type": "string",
        "default": ""
      },
      "clean_after_regex": {
        "description": "后置清理正则",
        "hint": "Regex 模式下，在分段后逐段执行正则清理。",
        "type": "string",
        "default": ""
      },
      "inject_kaomoji_prompt": {
        "description": "颜文字保护",
        "hint": "在请求前追加提示，减少颜文字被错误切分。",
        "type": "bool",
        "default": true
      }
    }
  },
  "reply_media_settings": {
    "description": "回复与组件",
    "type": "object",
    "hint": "控制 Reply 行为与图片、At、表情等组件的分段策略。",
    "items": {
      "enable_smart_reply": {
        "description": "智能回复",
        "hint": "发送前检测当前消息后是否已有新消息，有则给第一段加 Reply。",
        "type": "bool",
        "default": false
      },
      "enable_reply": {
        "description": "保留回复",
        "hint": "保留原有 Reply，并决定最后一段是否继续携带 Reply。",
        "type": "bool",
        "default": true
      },
      "image_strategy": {
        "description": "图片策略",
        "hint": "图片如何跟随上下文或单独发送。",
        "type": "string",
        "options": ["单独", "跟随下段", "跟随上段", "嵌入"],
        "default": "单独"
      },
      "at_strategy": {
        "description": "At 策略",
        "hint": "At 组件的分段归属方式。",
        "type": "string",
        "options": ["单独", "跟随下段", "跟随上段", "嵌入"],
        "default": "跟随下段"
      },
      "face_strategy": {
        "description": "表情策略",
        "hint": "表情组件的分段归属方式。",
        "type": "string",
        "options": ["单独", "跟随下段", "跟随上段", "嵌入"],
        "default": "嵌入"
      },
      "other_media_strategy": {
        "description": "其他组件策略",
        "hint": "未知组件的分段归属方式。",
        "type": "string",
        "options": ["单独", "跟随下段", "跟随上段", "嵌入"],
        "default": "跟随下段"
      }
    }
  },
  "delay_settings": {
    "description": "发送延迟",
    "type": "object",
    "hint": "控制分段发送间隔与延迟计算方式。",
    "items": {
      "delay_strategy": {
        "description": "延迟策略",
        "hint": "Linear 线性；Log 对数；Random 随机；Fixed 固定。",
        "type": "string",
        "options": ["linear", "log", "random", "fixed"],
        "default": "linear"
      },
      "linear_base": {
        "description": "线性基础值",
        "type": "float",
        "default": 0.5
      },
      "linear_factor": {
        "description": "线性字数系数",
        "type": "float",
        "default": 0.1
      },
      "log_base": {
        "description": "对数基础值",
        "type": "float",
        "default": 0.5
      },
      "log_factor": {
        "description": "对数系数",
        "type": "float",
        "default": 0.8
      },
      "random_min": {
        "description": "随机最小值",
        "type": "float",
        "default": 1.0
      },
      "random_max": {
        "description": "随机最大值",
        "type": "float",
        "default": 3.0
      },
      "fixed_delay": {
        "description": "固定延迟值",
        "type": "float",
        "default": 1.5
      }
    }
  }
}
